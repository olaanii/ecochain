{
  "name": "ecochain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "pnpm run build:verification && pnpm run build:seed",
    "build:verification": "tsc --project tsconfig.verification.json && node scripts/postprocess-verification.js",
    "build:seed": "tsc --project tsconfig.seed.json",
    "test:unit": "pnpm run build:verification && node tests/verification.test.js",
    "test:integration": "jest --config=jest.config.integration.js",
    "test:integration:watch": "jest --config=jest.config.integration.js --watch",
    "test:all": "pnpm run test:unit && pnpm run test:integration",
    "demo": "node scripts/demo-flow.js",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "pnpm run build:seed && node dist-seed/scripts/seed.js",
    "db:seed:prisma": "pnpm run build:seed && node dist-seed/scripts/seed-prisma.js",
    "db:seed:tasks": "pnpm run build:seed && node dist-seed/scripts/seed-tasks.js",
    "db:seed:rewards": "pnpm run build:seed && node dist-seed/scripts/seed-rewards.js",
    "db:seed:test": "pnpm run build:seed && node dist-seed/scripts/test-seed.js"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.7",
    "@initia/interwovenkit-react": "^2.5.1",
    "@prisma/client": "^7.6.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "dayjs": "1.11.13",
    "ioredis": "^5.3.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "viem": "^2.21.0",
    "wagmi": "^2.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jest": "^30.3.0",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}
