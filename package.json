{
  "name": "ecochain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "pnpm": {
    "overrides": {
      "@cosmjs/amino": "0.36.2",
      "@cosmjs/crypto": "0.36.2",
      "@cosmjs/encoding": "0.36.2",
      "@cosmjs/math": "0.36.2",
      "@cosmjs/proto-signing": "0.36.2",
      "@cosmjs/stargate": "0.36.2",
      "@cosmjs/tendermint-rpc": "0.36.2",
      "@initia/interwovenkit-react>@noble/hashes": "1.8.0",
      "@initia/utils>@noble/hashes": "1.8.0",
      "cosmjs-types": "0.9.0"
    }
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "pnpm run build:verification && pnpm run build:seed",
    "build:verification": "tsc --project tsconfig.verification.json && node scripts/postprocess-verification.js",
    "build:seed": "tsc --project tsconfig.seed.json",
    "test:unit": "pnpm run build:verification && node tests/verification.test.js",
    "test:integration": "jest --config=jest.config.integration.js",
    "test:integration:watch": "jest --config=jest.config.integration.js --watch",
    "test:unit:jest": "jest --config=jest.config.js",
    "test:all": "pnpm run test:unit && pnpm run test:unit:jest && pnpm run test:integration",
    "smoke:testnet": "ts-node -P tsconfig.seed.json scripts/smoke-testnet.ts",
    "prisma:migrate": "prisma migrate dev",
    "demo": "node scripts/demo-flow.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:load": "node tests/load/autocannon-load.js",
    "test:load:api": "node tests/load/autocannon-load.js --duration 30 --requests 1000",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "pnpm run build:seed && node dist-seed/scripts/seed.js",
    "db:seed:prisma": "pnpm run build:seed && node dist-seed/scripts/seed-prisma.js",
    "db:seed:tasks": "pnpm run build:seed && node dist-seed/scripts/seed-tasks.js",
    "db:seed:rewards": "pnpm run build:seed && node dist-seed/scripts/seed-rewards.js",
    "patch:interwovenkit": "node scripts/patch-interwovenkit.cjs",
    "predev": "node scripts/patch-interwovenkit.cjs",
    "prebuild": "node scripts/patch-interwovenkit.cjs",
    "prestart": "node scripts/patch-interwovenkit.cjs",
    "postinstall": "prisma generate && node scripts/patch-interwovenkit.cjs"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.7",
    "@initia/interwovenkit-react": "^2.5.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.215.0",
    "@opentelemetry/instrumentation-fetch": "^0.215.0",
    "@opentelemetry/instrumentation-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.6.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-toast": "^1.2.15",
    "@sentry/nextjs": "^10.49.0",
    "@tanstack/react-query": "^5.95.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "axios": "^1.14.0",
    "buffer": "^6.0.3",
    "clsx": "^2.1.1",
    "crypto-browserify": "^3.12.1",
    "dayjs": "1.11.13",
    "ioredis": "^5.3.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "pg-boss": "^12.15.0",
    "process": "^0.11.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "stream-browserify": "^3.0.0",
    "svix": "^1.90.0",
    "util": "^0.12.5",
    "viem": "^2.21.0",
    "wagmi": "^2.12.0",
    "web-push": "^3.6.7",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/autocannon": "^7.12.0",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "autocannon": "^7.15.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "pg": "^8.12.0",
    "playwright": "^1.49.0",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "testcontainers": "^10.9.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}
