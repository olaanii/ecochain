DATABASE_URL=postgresql://user:password@localhost:5432/ecochain?connection_limit=20&pool_timeout=10&connect_timeout=10

# Redis Configuration (Requirement 28.10)
# ---------------------------------------
# LOCAL DEV: leave these unset (or explicitly DISABLE_REDIS=1). The app ships
# with a no-op stub client that returns null for reads and 0 for writes, so
# caching, rate limiting, and the realtime SSE fan-out degrade gracefully
# when Redis isn't running. No more ECONNREFUSED flood.
#
# REAL REDIS: set EITHER `REDIS_URL=redis[s]://user:pass@host:port/db` OR the
# discrete fields below. A non-`localhost` REDIS_HOST auto-enables Redis; if
# you truly do want to point at a localhost Redis, also set REDIS_ENABLED=1.
# REDIS_URL=rediss://default:xxxx@fly-eco-redis.upstash.io:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_ENABLED=1        # opt-in if you're using localhost
# DISABLE_REDIS=1        # force stub even if the above are set

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=clerk.example.publishable
CLERK_SECRET_KEY=clerk.example.secret
# Clerk Dashboard → Webhooks → Signing Secret (whsec_...)
CLERK_WEBHOOK_SECRET=whsec_example
