# ---------------------------------------------------------------------------
# Contract deployment (Foundry, EVM-only)
# ---------------------------------------------------------------------------
# Used by contracts/script/deploy.s.sol. NEVER commit real values — these are
# the hot keys that control minting on the Verifier.
#
# PRIVATE_KEY      Deployer EOA (funds the broadcast; may also be admin).
# ADMIN_ADDRESS    Optional: multisig / TimelockController. Defaults to deployer.
# ORACLE_ADDRESS   Public address whose private key the off-chain oracle
#                  signer service holds. Rotate via AccessControl role grants
#                  — never by redeploying the contract.
# ECO_SUPPLY_CAP   Hard cap (wei) baked into EcoReward. Defaults to 1e27 (1B).
# PRIVATE_KEY=0x...
# ADMIN_ADDRESS=0x...
# ORACLE_ADDRESS=0x...
# ECO_SUPPLY_CAP=1000000000000000000000000000

# ---------------------------------------------------------------------------
# Off-chain oracle signer (server-side; signs EIP-712 Attestations)
# ---------------------------------------------------------------------------
# Must match ORACLE_ADDRESS above. Host in an isolated secret store (Vercel
# encrypted env, AWS KMS, 1Password Connect, etc.) — NEVER ship to the client.
# ORACLE_SIGNER_PRIVATE_KEY=0x...
# ORACLE_SIGNATURE_TTL_SECONDS=3600

# ---------------------------------------------------------------------------
# Sentry (SDK v10 — see sentry.{client,server,edge}.config.ts)
# ---------------------------------------------------------------------------
# Defaults are conservative in production (0.1 sample rate) to protect the
# free tier. Server-only DSN can be set via SENTRY_DSN if you want to split
# quotas between SSR and the browser.
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
NEXT_PUBLIC_VERSION=1.0.0
