{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "lib": ["es2022"],
    "outDir": "dist-seed"
  },
  "include": [
    "scripts/**/*.ts",
    "src/lib/data/**/*.ts",
    "src/lib/initia/submission.ts",
    "src/types/**/*.d.ts"
  ]
}
