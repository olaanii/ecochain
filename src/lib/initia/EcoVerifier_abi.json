[
  {
    "type": "function",
    "name": "submitProof",
    "stateMutability": "nonpayable",
    "inputs": [
      { "name": "taskId",    "type": "bytes32" },
      { "name": "proofHash", "type": "bytes32" },
      { "name": "reward",    "type": "uint256" },
      { "name": "nonce",     "type": "uint256" },
      { "name": "deadline",  "type": "uint256" },
      { "name": "signature", "type": "bytes"   }
    ],
    "outputs": []
  },
  {
    "type": "function",
    "name": "nonces",
    "stateMutability": "view",
    "inputs": [{ "name": "user", "type": "address" }],
    "outputs": [{ "name": "",    "type": "uint256" }]
  },
  {
    "type": "function",
    "name": "usedProofHashes",
    "stateMutability": "view",
    "inputs": [{ "name": "proofHash", "type": "bytes32" }],
    "outputs": [{ "name": "",         "type": "bool"    }]
  },
  {
    "type": "function",
    "name": "tasks",
    "stateMutability": "view",
    "inputs": [{ "name": "taskId", "type": "bytes32" }],
    "outputs": [
      { "name": "baseReward", "type": "uint256" },
      { "name": "maxReward",  "type": "uint256" },
      { "name": "active",     "type": "bool"    },
      { "name": "exists",     "type": "bool"    }
    ]
  },
  {
    "type": "function",
    "name": "ecoToken",
    "stateMutability": "view",
    "inputs": [],
    "outputs": [{ "name": "", "type": "address" }]
  },
  {
    "type": "function",
    "name": "paused",
    "stateMutability": "view",
    "inputs": [],
    "outputs": [{ "name": "", "type": "bool" }]
  },
  {
    "type": "function",
    "name": "domainSeparator",
    "stateMutability": "view",
    "inputs": [],
    "outputs": [{ "name": "", "type": "bytes32" }]
  },
  {
    "type": "function",
    "name": "hashAttestation",
    "stateMutability": "view",
    "inputs": [
      { "name": "user",      "type": "address" },
      { "name": "taskId",    "type": "bytes32" },
      { "name": "proofHash", "type": "bytes32" },
      { "name": "reward",    "type": "uint256" },
      { "name": "nonce",     "type": "uint256" },
      { "name": "deadline",  "type": "uint256" }
    ],
    "outputs": [{ "name": "", "type": "bytes32" }]
  },
  {
    "type": "function",
    "name": "ORACLE_ROLE",
    "stateMutability": "view",
    "inputs": [],
    "outputs": [{ "name": "", "type": "bytes32" }]
  },
  {
    "type": "function",
    "name": "hasRole",
    "stateMutability": "view",
    "inputs": [
      { "name": "role",    "type": "bytes32" },
      { "name": "account", "type": "address" }
    ],
    "outputs": [{ "name": "", "type": "bool" }]
  },
  {
    "type": "event",
    "name": "ProofSubmitted",
    "anonymous": false,
    "inputs": [
      { "name": "user",      "type": "address", "indexed": true  },
      { "name": "taskId",    "type": "bytes32", "indexed": true  },
      { "name": "proofHash", "type": "bytes32", "indexed": true  },
      { "name": "reward",    "type": "uint256", "indexed": false },
      { "name": "nonce",     "type": "uint256", "indexed": false }
    ]
  },
  {
    "type": "event",
    "name": "TaskSet",
    "anonymous": false,
    "inputs": [
      { "name": "taskId",     "type": "bytes32", "indexed": true  },
      { "name": "baseReward", "type": "uint256", "indexed": false },
      { "name": "maxReward",  "type": "uint256", "indexed": false },
      { "name": "active",     "type": "bool",    "indexed": false }
    ]
  },
  {
    "type": "event",
    "name": "Paused",
    "anonymous": false,
    "inputs": [{ "name": "account", "type": "address", "indexed": false }]
  },
  {
    "type": "event",
    "name": "Unpaused",
    "anonymous": false,
    "inputs": [{ "name": "account", "type": "address", "indexed": false }]
  },
  {
    "type": "error",
    "name": "BadSigner",
    "inputs": [{ "name": "signer", "type": "address" }]
  },
  {
    "type": "error",
    "name": "ProofReused",
    "inputs": [{ "name": "proofHash", "type": "bytes32" }]
  },
  {
    "type": "error",
    "name": "SignatureExpired",
    "inputs": [
      { "name": "deadline", "type": "uint256" },
      { "name": "nowTs",    "type": "uint256" }
    ]
  },
  {
    "type": "error",
    "name": "InvalidNonce",
    "inputs": [
      { "name": "expected", "type": "uint256" },
      { "name": "provided", "type": "uint256" }
    ]
  },
  {
    "type": "error",
    "name": "RewardTooHigh",
    "inputs": [
      { "name": "requested", "type": "uint256" },
      { "name": "cap",       "type": "uint256" }
    ]
  },
  {
    "type": "error",
    "name": "TaskUnknown",
    "inputs": [{ "name": "taskId", "type": "bytes32" }]
  },
  {
    "type": "error",
    "name": "TaskInactive",
    "inputs": [{ "name": "taskId", "type": "bytes32" }]
  },
  { "type": "error", "name": "ZeroReward", "inputs": [] },
  { "type": "error", "name": "ZeroAddress", "inputs": [] }
]
